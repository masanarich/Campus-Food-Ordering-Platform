rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveAccount() {
      return signedIn() &&
        currentUserDoc().data.accountStatus == "active";
    }

    function isAdmin() {
      return signedIn() &&
        currentUserDoc().data.isAdmin == true &&
        currentUserDoc().data.accountStatus == "active";
    }

    function canManageOwnVendorResources(userId) {
      return isSelf(userId) &&
        isActiveAccount() &&
        (
          currentUserDoc().data.vendorStatus == "approved" ||
          currentUserDoc().data.isAdmin == true
        );
    }

    function orderDoc(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId));
    }

    function orderExists(orderId) {
      return exists(/databases/$(database)/documents/orders/$(orderId));
    }

    function isOrderParticipantById(orderId) {
      return signedIn() &&
        orderExists(orderId) &&
        (
          orderDoc(orderId).data.customerUid == request.auth.uid ||
          orderDoc(orderId).data.vendorUid == request.auth.uid ||
          isAdmin()
        );
    }

    function isNotificationRecipientData(data) {
      return signedIn() &&
        request.auth.uid == data.recipientUid;
    }

    function isOwnPendingVendorSubmission(before, after) {
      let oldStatus = before.vendorStatus;
      let newStatus = after.vendorStatus;

      return (
        oldStatus == newStatus ||
        (
          (oldStatus == "none" || oldStatus == "rejected") &&
          newStatus == "pending" &&
          after.vendorReason == ""
        )
      );
    }

    function isOwnPendingAdminSubmission(before, after) {
      let oldStatus = before.adminApplicationStatus;
      let newStatus = after.adminApplicationStatus;

      return (
        oldStatus == newStatus ||
        (
          before.isAdmin == false &&
          (oldStatus == "none" || oldStatus == "rejected") &&
          newStatus == "pending" &&
          after.isAdmin == false &&
          after.adminApplicationReason == ""
        )
      );
    }

    function selfCanUpdateOwnProfile(userId) {
      return isSelf(userId) &&
        request.resource.data.uid == userId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.isAdmin == resource.data.isAdmin &&
        request.resource.data.accountStatus == resource.data.accountStatus &&
        isOwnPendingVendorSubmission(resource.data, request.resource.data) &&
        isOwnPendingAdminSubmission(resource.data, request.resource.data);
    }

    function validApplicationOwner(docId) {
      return signedIn() &&
        request.auth.uid == docId &&
        request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if isSelf(userId) &&
        request.resource.data.uid == userId;

      // Signed-in users need to browse vendor profiles from the users collection.
      // This is intentionally permissive for the course project so customer pages
      // can query approved vendors directly from Firestore.
      allow get, list: if signedIn() || isAdmin();

      allow update: if isAdmin() || selfCanUpdateOwnProfile(userId);

      allow delete: if isSelf(userId) || isAdmin();

      match /menuItems/{productId} {
        allow get, list: if signedIn();

        allow create: if canManageOwnVendorResources(userId) &&
          request.resource.data.vendorUid == userId;

        allow update: if canManageOwnVendorResources(userId) &&
          request.resource.data.vendorUid == userId &&
          request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if canManageOwnVendorResources(userId);
      }
    }

    match /vendorApplications/{userId} {
      allow get: if isSelf(userId) || isAdmin();
      allow list: if isAdmin();

      allow create, update: if (
        validApplicationOwner(userId) &&
        request.resource.data.vendorStatus == "pending" &&
        request.resource.data.vendorReason == ""
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /adminApplications/{userId} {
      allow get: if isSelf(userId) || isAdmin();
      allow list: if isAdmin();

      allow create, update: if (
        validApplicationOwner(userId) &&
        request.resource.data.isAdmin == false &&
        request.resource.data.adminApplicationStatus == "pending" &&
        request.resource.data.adminApplicationReason == ""
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      function isOrderCustomerData(data) {
        return signedIn() &&
          request.auth.uid == data.customerUid &&
          isActiveAccount();
      }

      function isOrderVendorData(data) {
        return signedIn() &&
          request.auth.uid == data.vendorUid &&
          isActiveAccount() &&
          currentUserDoc().data.vendorStatus == "approved";
      }

      function isOrderParticipantData(data) {
        return isOrderCustomerData(data) || isOrderVendorData(data) || isAdmin();
      }

      function isValidOrderCreation() {
        return signedIn() &&
          isActiveAccount() &&
          request.resource.data.customerUid == request.auth.uid &&
          request.resource.data.vendorUid is string &&
          request.resource.data.vendorUid != "" &&
          request.resource.data.orderId is string &&
          request.resource.data.orderId == orderId &&
          request.resource.data.status == "pending" &&
          request.resource.data.itemCount > 0 &&
          request.resource.data.total > 0 &&
          request.resource.data.items is list &&
          request.resource.data.items.size() > 0 &&
          request.resource.data.timeline is list &&
          request.resource.data.timeline.size() > 0 &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.updatedAt is timestamp;
      }

      function immutableOrderFieldsPreserved() {
        return request.resource.data.orderId == resource.data.orderId &&
          request.resource.data.customerUid == resource.data.customerUid &&
          request.resource.data.customerName == resource.data.customerName &&
          request.resource.data.customerEmail == resource.data.customerEmail &&
          request.resource.data.vendorUid == resource.data.vendorUid &&
          request.resource.data.vendorName == resource.data.vendorName &&
          request.resource.data.items == resource.data.items &&
          request.resource.data.itemCount == resource.data.itemCount &&
          request.resource.data.subtotal == resource.data.subtotal &&
          request.resource.data.total == resource.data.total &&
          request.resource.data.createdAt == resource.data.createdAt;
      }

      function onlyAllowedOrderFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "timeline",
          "updatedAt",
          "notes",
          "customerConfirmedCollected",
          "vendorConfirmedCollected"
        ]);
      }

      function validOrderUpdateShape() {
        return immutableOrderFieldsPreserved() &&
          onlyAllowedOrderFieldsChanged() &&
          request.resource.data.timeline is list &&
          request.resource.data.timeline.size() >= resource.data.timeline.size() &&
          request.resource.data.updatedAt != resource.data.updatedAt;
      }

      function isValidStatusTransition() {
        let oldStatus = resource.data.status;
        let newStatus = request.resource.data.status;
        let actorUid = request.auth.uid;
        let isVendor = actorUid == resource.data.vendorUid;
        let isCustomer = actorUid == resource.data.customerUid;

        // Vendor transitions
        let vendorCanTransition = isVendor && (
          (oldStatus == "pending" && (newStatus == "accepted" || newStatus == "rejected")) ||
          (oldStatus == "accepted" && newStatus == "preparing") ||
          (oldStatus == "preparing" && newStatus == "ready")
        );

        // Customer transitions
        let customerCanTransition = isCustomer && (
          (oldStatus == "pending" && newStatus == "cancelled") ||
          (oldStatus == "ready" && newStatus == "completed")
        );

        return vendorCanTransition || customerCanTransition || isAdmin();
      }

      function isValidCollectionConfirmation() {
        let actorUid = request.auth.uid;
        let isVendor = actorUid == resource.data.vendorUid;
        let isCustomer = actorUid == resource.data.customerUid;
        let oldStatus = resource.data.status;
        let newStatus = request.resource.data.status;

        // Can only confirm when status is "ready" or "completed"
        return (oldStatus == "ready" || oldStatus == "completed") &&
          (
            (newStatus == "ready" || newStatus == "completed") &&
            (
              (isVendor &&
                request.resource.data.customerConfirmedCollected == resource.data.customerConfirmedCollected &&
                request.resource.data.vendorConfirmedCollected == true) ||
              (isCustomer &&
                request.resource.data.vendorConfirmedCollected == resource.data.vendorConfirmedCollected &&
                request.resource.data.customerConfirmedCollected == true)
            )
          );
      }

      function canUpdateOrder() {
        return validOrderUpdateShape() && (
          isValidStatusTransition() ||
          isValidCollectionConfirmation()
        );
      }

      // Create: Only customers can create orders for themselves
      allow create: if isValidOrderCreation();

      // Read: customer, vendor, or admin can only read participating orders
      allow read: if isOrderParticipantData(resource.data);

      // Update: Customer or vendor can update with restrictions
      allow update: if (isOrderCustomerData(resource.data) || isOrderVendorData(resource.data) || isAdmin()) &&
        canUpdateOrder();

      // Delete: Admin only (for data management)
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      function isValidNotificationCreation() {
        return signedIn() &&
          isActiveAccount() &&
          request.resource.data.recipientUid is string &&
          request.resource.data.recipientUid != "" &&
          request.resource.data.recipientRole is string &&
          request.resource.data.type is string &&
          request.resource.data.title is string &&
          request.resource.data.message is string &&
          request.resource.data.read == false &&
          request.resource.data.createdAt is timestamp;
      }

      function canUpdateNotification() {
        return isNotificationRecipientData(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]) &&
          request.resource.data.read is bool;
      }

      function canCreateNotification() {
        return isValidNotificationCreation() &&
          (
            !("orderId" in request.resource.data) ||
            (
              request.resource.data.orderId is string &&
              request.resource.data.orderId != "" &&
              isOrderParticipantById(request.resource.data.orderId)
            )
          );
      }

      // Create: allow authenticated order participants or admins to create related notifications
      allow create: if canCreateNotification();

      // Read: Only recipient can view their notifications
      allow read: if isNotificationRecipientData(resource.data) || isAdmin();

      // Update: Only recipient can mark as read
      allow update: if canUpdateNotification();

      // Delete: Recipient or admin can delete
      allow delete: if isNotificationRecipientData(resource.data) || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
